[MASTER]
ignore=venv,.git
jobs=1

[FORMAT]
max-line-length=140

[MESSAGES CONTROL]
disable=
    missing-module-docstring,
    missing-class-docstring,
    missing-function-docstring,
    invalid-name,
    too-many-lines,
    too-many-branches,
    too-many-statements,
    too-many-return-statements,
    too-many-arguments,
    too-many-positional-arguments,
    too-many-instance-attributes,
    too-many-locals,
    too-many-public-methods,
    broad-exception-caught,
    logging-fstring-interpolation,
    consider-using-in,
    no-else-return,
    unused-import,
    wrong-import-order,
    import-error,
    no-member,
    bare-except,
    f-string-without-interpolation,
    duplicate-code
